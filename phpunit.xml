<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <!-- force="true" sur chaque variable : le conteneur Docker expose déjà
         APP_ENV/CACHE_STORE/DB_* comme variables d'environnement OS réelles
         (héritées de .env par Docker Compose). Depuis PHPUnit 10, <env> sans
         force="true" n'écrase pas une variable d'environnement déjà définie
         au niveau du process — sans cet attribut, ces surcharges sont
         silencieusement ignorées et les tests tournent avec la config de
         développement (base `lowly`, cache Redis) au lieu de l'environnement
         de test. -->
    <php>
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="BROADCAST_CONNECTION" value="null" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <!-- PostgreSQL requis (pas sqlite) : les migrations Reservation/Availability
             utilisent daterange, EXCLUDE USING gist et gen_random_uuid(), voir
             TESTING.md §5 et docs/engineering/08-database-guidelines.md §5. Base
             dédiée pour ne jamais toucher aux données de développement. -->
        <env name="DB_CONNECTION" value="pgsql" force="true"/>
        <env name="DB_DATABASE" value="lowly_testing" force="true"/>
        <env name="DB_URL" value="" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
